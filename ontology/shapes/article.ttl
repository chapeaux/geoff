@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix geoff:  <https://geoff.chapeaux.io/ontology#> .

# =============================================================================
# SHACL Shape: Article
# Validates content typed as schema:Article
# =============================================================================

geoff:ArticleShape a sh:NodeShape ;
    sh:targetClass schema:Article ;
    rdfs:label "Article" ;
    rdfs:comment "Validates that an article has the required metadata for publishing." ;

    sh:property [
        sh:path schema:name ;
        sh:name "title" ;
        sh:description "Every article must have exactly one title." ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path schema:datePublished ;
        sh:name "date" ;
        sh:description "Every article must have exactly one publication date." ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path schema:author ;
        sh:name "author" ;
        sh:description "Every article must have at least one author." ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path schema:description ;
        sh:name "description" ;
        sh:description "An article may have at most one description." ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Warning ;
    ] .
