@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix geoff:  <https://geoff.chapeaux.io/ontology#> .

# =============================================================================
# SHACL Shape: Blog Post
# Validates content typed as schema:BlogPosting
# =============================================================================

geoff:BlogPostShape a sh:NodeShape ;
    sh:targetClass schema:BlogPosting ;
    rdfs:label "Blog Post" ;
    rdfs:comment "Validates that a blog post has the required metadata." ;

    sh:property [
        sh:path schema:name ;
        sh:name "title" ;
        sh:description "Every blog post must have exactly one title." ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path schema:datePublished ;
        sh:name "date" ;
        sh:description "Every blog post must have exactly one publication date." ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:severity sh:Violation ;
    ] ;

    sh:property [
        sh:path schema:author ;
        sh:name "author" ;
        sh:description "A blog post may have at most one author." ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
    ] ;

    sh:property [
        sh:path schema:keywords ;
        sh:name "tags" ;
        sh:description "A blog post may have any number of tags." ;
        sh:datatype xsd:string ;
        sh:severity sh:Info ;
    ] ;

    sh:property [
        sh:path schema:description ;
        sh:name "description" ;
        sh:description "A blog post may have a short summary." ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Info ;
    ] .
